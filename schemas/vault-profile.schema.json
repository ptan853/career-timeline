{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-vault.dev/schemas/vault-profile.schema.json",
  "title": "VaultProfile",
  "type": "object",
  "required": ["schema_version", "user", "privacy"],
  "properties": {
    "schema_version": { "const": 1 },
    "user": {
      "type": "object",
      "required": ["display_name", "headline", "default_locale", "target_roles"],
      "properties": {
        "display_name": { "type": "string" },
        "headline": { "type": "string" },
        "default_locale": { "type": "string" },
        "target_roles": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "required": ["default_visibility", "public_summary_allowed"],
      "properties": {
        "default_visibility": {
          "type": "string",
          "enum": ["private", "resume", "public"]
        },
        "public_summary_allowed": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
